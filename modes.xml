<?xml version="1.0" encoding="UTF-8"?>
<modes>

  <mode name="jta-twol" install="no">
    <pipeline>
      <program name="hfst-strings2fst -S"/>
      <program name="hfst-compose-intersect">
        <file name=".deps/jta.twol.hfst"/>
      </program>
      <program name="hfst-fst2strings"/>
    </pipeline>
  </mode>

  <mode name="jta-morph" install="yes">
    <pipeline>
      <program name="lt-proc -w">
        <file name="jta.automorf.bin"/>
      </program>
    </pipeline>
  </mode>


  <mode name="jta-lexd" install="no">
    <pipeline>
      <program name="hfst-lookup">
        <file name=".deps/jta.LR.lexd.hfst"/>
      </program>
    </pipeline>
  </mode>

  <mode name="jta-gener" install="yes">
    <pipeline>
      <program name="lt-proc -g">
        <file name="jta.autogen.bin"/>
      </program>
    </pipeline>
  </mode>

  <mode name="jta-tagger" install="yes">
    <pipeline>
      <program name="lt-proc -w">
        <file name="jta.automorf.bin"/>
      </program>
      <program name="cg-proc -w">
        <file name="jta.rlx.bin"/>
      </program>
    </pipeline>
  </mode>

  <mode name="jta-disam" install="yes">
    <pipeline>
      <program name="lt-proc -w">
        <file name="jta.automorf.bin"/>
      </program>
      <program name="cg-conv -a"/>
      <program name="vislcg3 --trace --grammar">
        <file name="jta.rlx.bin"/>
      </program>
    </pipeline>
  </mode>

  <mode name="jta-paradigm" install="yes">
    <pipeline>
      <program name="lt-paradigm -s">
        <file name="jta.autogen.bin"/>
      </program>
    </pipeline>
  </mode>

</modes>


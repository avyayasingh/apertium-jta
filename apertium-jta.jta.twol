Alphabet
    அ ஆ இ ஈ உ ஊ எ ஏ ஐ ஒ ஓ ஔ ஃ க ங ச ஞ	ட ண த ந ப ம ய ர ல வ	ழ ள ற ன
   ா ி  ீ  ு  ூ  ெ  ே  ை  ொ  ோ  ௌ  ௗ   ்
     %{X%}:0
     ! Vowels
     %{AI%}:ை
     %{A%}:0
     %{AA%}:ா
     %{U%}:ு %{U%}:0
     %{OO%}:ோ
     %{I%}:ி
     %{II%}:ீ
     ! Pulli
     %{Pul%}:் %{Pul%}:0
     ! Consonants
     %{M%}:ம %{M%}:த %{M%}:ங
     %{N%}:ன %{N%}:ங
     %{K%}:க
     ! Noun case irregulars
     %{Irefr%}:ி %{Irefr%}:0
     %{Igen%}:ி %{Igen%}:0
     %{Ngen1%}:ன
     %{Ngen2%}:ன %{Ngen2%}:0
     %{Rgen1%}:ர
     %{Rgen2%}:ர %{Rgen2%}:0
     %>:0;


Sets

Consonant = க ங ச ஞ	ட ண த ந ப ம ய ர ல வ	ழ ள ற ன ;
Mellinam = ங ஞ ண ந ம ன;
Vallinam = க ச ட த ப ற;
Idaiyinam = ய ர ல வ ழ ள;

RemConsonant = Mellinam ல ;

Vowel = அ ஆ இ ஈ உ ஊ எ ஏ ஐ ஒ ஓ ஔ ஃ ;
VowWithSym = ஆ இ ஈ உ ஊ எ ஏ ஐ ஒ ஓ ஔ ;
VowSym = ா  ி  ீ  ு  ூ  ெ  ே  ை  ொ  ோ  ௌ ;
ShortVowSym = ி  ு  ெ  ை  ொ;
LongVowSym =  ா  ீ  ூ  ே  ோ  ௌ;

Rules 

! "Ending with ல"
! X:ற <=> ல:  ்: %>: _ ;
!               except
!                ி: ல:  ்: %>: _ ;
!                ோ: ல:  ்: %>: _ ;

! "Ending with ல"
! X:ல <=> Vx: ல:  ்: %>: _ ;
!               where Vx in ( ி  ோ ) ;

! "Ending with ல"
! X:வ <=>  ா: _ %»:;

! "Inserting ல"
! X:ல <=> Vallinam: ல:   ்: _ %»:;
!             except 
!             ட: ல:   ்: _ %»:;


! "Changing to ட"
! X:ட <=> VowSym: ட:  ு: _ %»:;

! "Removing  ு"
!  ு:Vx <=> VowSym: ட: _ X: %»:;
!           where Vx in (  ் ) ;

! "Removing  ு"
!  ு:0 <=> வ: _ X: %»:;
!           க: _ X: %»:;
!            ்: ட: _ X: %»:;

! Pulli
"Removing Pulli when adding Suffix"
%{Pul%}:0 <=> :RemConsonant _ %>: [ %{A%}: | %{AI%}: | %{OO%}: | %{U%}: | %{I%}: | %{II%}: | %{AA%}: | %{Irefr%}: | %{Igen%}: ] ;
              %{Ngen2%}: _ %{Rgen2%}: ;
                except 
                ப: ல: _ %>: ;
                %{M%}: _ %>: ;  

"Keeping Pulli when end of word or consonant follows"
%{Pul%}:் <=> :RemConsonant _ .#. ;
              :RemConsonant _ %>: :RemConsonant ;

"Adding Pulli"
0:Vy <=> LongVowSym: %>: C: _ C: ;
         where Vy in ( ் )
         and C in Vallinam ;

! M ending pulli
"Keep M to m if end of word"
%{M%}:ம <=> _ %{Pul%}: .#. ;

"Transform underlying M to T when vowel"
%{M%}:த <=> _ %{Pul%}: %>: [ %{AI%}: | %{OO%}: | %{U%}: | %{I%}: | %{II%}: | %{AA%}: | %{Irefr%}: | %{Igen%}: ] ;

"Force the Pulli"
%{Pul%}:் <=> %{M%}: _ %>: [ %{AI%}: | %{OO%}: | %{U%}: | %{I%}: | %{II%}: | %{AA%}: | %{Irefr%}: | %{Igen%}: ] ;

"Insert a second T"
0:த <=> %{M%}: %{Pul%}: %>: _ [ %{AI%}: | %{OO%}: | %{U%}: | %{I%}: | %{II%}: | %{AA%}: | %{Irefr%}: | %{Igen%}: ] ;

! Referential case
"Removing I when Referential and noun ends in AA"
%{Irefr%}:0 <=> %{AA%}: %>: _ ;

! Genitive case
"Removing I when Genitive and human noun ends in N or R"
%{Igen%}:0 <=> [ %{Ngen1%}: | %{Rgen1%}: ] %{Pul%}: %>: _ ;

"Removing N when Genitive and noun ends in N or R"
%{Ngen2%}:0 <=> [ %{Ngen1%}: | %{Rgen1%}: ] %{Pul%}: %>: %{Igen%}: _ ;

! Noun endings 
"Inserting ய"
0:ய <=> [ %{AI%}: | %{I%}: ] _ %>:;

"Removing  ு"
%{U%}:0 <=> _ %>: [ %{AI%}: | %{OO%}: | %{U%}: | %{I%}: | %{II%}: | %{AA%}: ] ;
            [ %{AI%}: | %{OO%}: | %{U%}: | %{I%}: | %{II%}: | %{AA%}: ] %>: _ ;

"Starting with K"
%{M%}:ங <=> _ %{Pul%}: %>: %{K%}: ;

"Starting with K"
%{N%}:ங <=> _ %{Pul%}: %>: %{K%}: ;

